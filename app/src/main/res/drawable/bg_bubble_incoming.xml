<?xml version="1.0" encoding="utf-8"?>
<!-- Incoming message bubble: echo_card_surface, 16dp corners, 4dp bottom-left. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/echo_card_surface" />
    <corners
        android:topLeftRadius="@dimen/bubble_corner_radius"
        android:topRightRadius="@dimen/bubble_corner_radius"
        android:bottomLeftRadius="@dimen/bubble_corner_small"
        android:bottomRightRadius="@dimen/bubble_corner_radius" />
</shape>
