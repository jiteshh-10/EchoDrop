<?xml version="1.0" encoding="utf-8"?>
<!-- Outgoing message bubble: echo_primary_tint, 16dp corners, 4dp bottom-right. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/echo_primary_tint" />
    <corners
        android:topLeftRadius="@dimen/bubble_corner_radius"
        android:topRightRadius="@dimen/bubble_corner_radius"
        android:bottomLeftRadius="@dimen/bubble_corner_radius"
        android:bottomRightRadius="@dimen/bubble_corner_small" />
</shape>
