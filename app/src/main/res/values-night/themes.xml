<resources>

    <!-- ═══ Dark Theme (night) ═══ -->
    <style name="Theme.EchoDrop" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/echo_primary_accent</item>
        <item name="colorOnPrimary">@color/echo_on_primary</item>
        <item name="colorSurface">@color/echo_card_surface</item>
        <item name="colorOnSurface">@color/echo_text_primary</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.EchoDrop.MaterialAlertDialog</item>
        <item name="android:colorBackground">@color/echo_bg_main</item>
        <item name="colorOnBackground">@color/echo_text_primary</item>
        <item name="colorError">@color/echo_alert_accent</item>
        <item name="colorOnError">@color/echo_text_primary</item>
        <item name="android:statusBarColor">@color/echo_elevated_surface</item>
        <item name="android:navigationBarColor">@color/echo_elevated_surface</item>
        <!-- Apply DM Sans (sans-serif) globally via theme -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <!-- Dialog theme -->
    <style name="Theme.EchoDrop.Dialog" parent="Theme.Material3.Dark.Dialog.Alert">
        <item name="colorPrimary">@color/echo_primary_accent</item>
        <item name="colorOnPrimary">@color/echo_on_primary</item>
        <item name="colorSurface">@color/echo_card_surface</item>
        <item name="colorOnSurface">@color/echo_text_primary</item>
        <item name="android:colorBackground">@color/echo_elevated_surface</item>
        <item name="android:textColorPrimary">@color/echo_text_primary</item>
        <item name="android:textColorSecondary">@color/echo_text_secondary</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.EchoDrop.MaterialAlertDialog</item>
    </style>

    <style name="ThemeOverlay.EchoDrop.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">@color/echo_elevated_surface</item>
        <item name="colorOnSurface">@color/echo_text_primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.EchoDrop.DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.EchoDrop.DialogBody</item>
        <item name="android:textColorPrimary">@color/echo_text_primary</item>
        <item name="android:textColorSecondary">@color/echo_text_secondary</item>
    </style>

    <style name="TextAppearance.EchoDrop.DialogTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/echo_text_primary</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.EchoDrop.DialogBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/echo_text_secondary</item>
    </style>

</resources>