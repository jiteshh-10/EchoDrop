    <!-- Battery Guide (Iteration 5) -->
    <string name="battery_title">battery guide</string>
    <string name="battery_intro">some phones aggressively kill background apps. follow steps for your device.</string>
    <string name="battery_samsung">samsung</string>
    <string name="battery_samsung_step1">Settings → Apps → EchoDrop → Battery → \"Unrestricted\"</string>
    <string name="battery_samsung_step2">Settings → Battery → Background usage limits → disable for EchoDrop</string>
    <string name="battery_xiaomi">xiaomi / miui</string>
    <string name="battery_xiaomi_step1">Settings → Apps → Manage apps → EchoDrop → Battery saver → \"No restrictions\"</string>
    <string name="battery_xiaomi_step2">Security app → Permissions → Autostart → enable EchoDrop</string>
    <string name="battery_oneplus">oneplus / oxygenos</string>
    <string name="battery_oneplus_step1">Settings → Battery → Battery Optimization → EchoDrop → \"Don\'t optimize\"</string>
    <string name="battery_realme">realme / coloros</string>
    <string name="battery_realme_step1">Settings → App management → App list → EchoDrop → Battery usage → \"Allow background activity\"</string>
    <string name="battery_realme_step2">Phone Manager → Auto launch management → enable EchoDrop</string>
    <string name="battery_stock">stock android</string>
    <string name="battery_stock_step1">Settings → Apps → EchoDrop → Battery → \"Unrestricted\"</string>
