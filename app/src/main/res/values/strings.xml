    <string name="onboarding_feature_2_title">Messages expire automatically</string>
    <string name="onboarding_feature_2_sub">Every message deletes itself after 1-24 hours</string>
    <string name="onboarding_feature_3_title">No accounts, no servers</string>
    <string name="onboarding_feature_3_sub">Nothing is stored in the cloud</string>

