    <string name="app_name">EchoDrop</string>
    <string name="onboarding_headline">Offline messages, without the internet.</string>
    <string name="onboarding_subheading">EchoDrop relays short messages between nearby phones. Messages expire automatically and are never stored online.</string>
    <string name="onboarding_get_started">Get Started</string>
    <string name="onboarding_see_how">See how it works</string>
