    <string name="how_it_works_title">How It Works</string>
    <string name="how_it_works_section">The process</string>
    <string name="how_it_works_step_1">1 - Post a message with a scope and priority.</string>
    <string name="how_it_works_step_2">2 - Your phone shares it with nearby phones via Bluetooth.</string>
    <string name="how_it_works_step_3">3 - Those phones pass it along to their neighbours.</string>
    <string name="how_it_works_step_4">4 - The message deletes itself when its time runs out.</string>
