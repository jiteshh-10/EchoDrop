    <string name="how_it_works_title">how it works</string>
    <string name="how_it_works_headline">Delay-Tolerant Messaging</string>
    <string name="how_it_works_subheading">EchoDrop creates a mesh network between nearby phones, relaying messages without internet.</string>
    <string name="how_it_works_section">The Process</string>
    <string name="how_it_works_step_1">You post a message with a scope (LOCAL, ZONE, or EVENT) and priority.</string>
    <string name="how_it_works_step_2">Your phone broadcasts the message to nearby devices via Bluetooth/Wi-Fi.</string>
    <string name="how_it_works_step_3">Those devices forward it to their neighbors, creating a multi-hop relay.</string>
    <string name="how_it_works_step_4">Messages expire after their TTL, preventing network spam.</string>
    <string name="how_it_works_key_features">Key Features</string>
    <string name="how_it_works_tile_1_title">Mesh Networking</string>
    <string name="how_it_works_tile_1_sub">Messages hop between nearby phones using Bluetooth LE and Wi-Fi Direct, creating a delay-tolerant network.</string>
    <string name="how_it_works_tile_2_title">Automatic Expiry</string>
    <string name="how_it_works_tile_2_sub">All messages have a TTL (Time To Live). They automatically delete after 1, 6, or 24 hours.</string>
    <string name="how_it_works_tile_3_title">Temporary &amp; Private</string>
    <string name="how_it_works_tile_3_sub">No servers, no internet. Messages exist only on nearby devices and expire automatically.</string>
    <string name="how_it_works_tile_4_title">Priority Routing</string>
    <string name="how_it_works_tile_4_sub">Urgent alerts are forwarded first. Messages with higher priority get preferential relay.</string>
    <string name="how_it_works_use_cases">Use Cases</string>
    <string name="how_it_works_use_case_campus_title">Campus Communication</string>
    <string name="how_it_works_use_case_campus_sub">Share event updates, study group info, or campus alerts when internet is unreliable.</string>
    <string name="how_it_works_use_case_campus_icon">🎓</string>
    <string name="how_it_works_use_case_emergency_title">Emergency Situations</string>
    <string name="how_it_works_use_case_emergency_sub">During disasters when cell towers fail, relay important information person-to-person.</string>
    <string name="how_it_works_use_case_emergency_icon">🚨</string>
    <string name="how_it_works_got_it">got it</string>
    <string name="how_it_works_use_case_events_title">Conferences &amp; Events</string>
    <string name="how_it_works_use_case_events_sub">Create event-scoped messages that only propagate within the venue.</string>
    <string name="how_it_works_use_case_events_icon">🎤</string>
    <string name="how_it_works_get_started">got it</string>
    <string name="how_it_works_technical_title">Technical Implementation</string>
    <string name="how_it_works_tech_1">- Uses Bluetooth Low Energy (BLE) for discovery</string>
    <string name="how_it_works_tech_2">- Wi-Fi Direct for high-bandwidth transfers</string>
    <string name="how_it_works_tech_3">- Epidemic routing protocol with TTL-based eviction</string>
    <string name="how_it_works_tech_4">- Duplicate detection via message hash</string>
    <string name="how_it_works_tech_5">- Priority-based forwarding queue</string>

