<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- HTML-aligned typography -->

    <!-- Display -->
    <style name="TextAppearance.EchoDrop.Display" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/echo_text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <!-- H1 -->
    <style name="TextAppearance.EchoDrop.H1" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/echo_text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineSpacingMultiplier">1.25</item>
    </style>

    <!-- H2 -->
    <style name="TextAppearance.EchoDrop.H2" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/echo_text_primary</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:lineSpacingMultiplier">1.25</item>
    </style>

    <!-- Body Large -->
    <style name="TextAppearance.EchoDrop.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/echo_text_primary</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>

    <!-- Body -->
    <style name="TextAppearance.EchoDrop.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/echo_text_primary</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>

    <!-- Caption -->
    <style name="TextAppearance.EchoDrop.Small" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/echo_text_secondary</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <!-- Mono -->
    <style name="TextAppearance.EchoDrop.Mono" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/echo_text_primary</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Button -->
    <style name="TextAppearance.EchoDrop.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/echo_text_primary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Badge -->
    <style name="TextAppearance.EchoDrop.Badge" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">9sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- ═══ Button Styles ═══ -->

    <!-- Primary button -->
    <style name="Widget.EchoDrop.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">50dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="backgroundTint">@color/echo_primary_accent</item>
        <item name="android:textColor">@color/echo_on_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Secondary button -->
    <style name="Widget.EchoDrop.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">44dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="strokeColor">@color/echo_btn_secondary_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/echo_primary_accent</item>
        <item name="android:textSize">11sp</item>
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Ghost button -->
    <style name="Widget.EchoDrop.Button.Ghost" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">44dp</item>
        <item name="android:textColor">@color/echo_primary_accent</item>
        <item name="android:textSize">11sp</item>
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- ═══ BottomSheet ═══ -->

    <style name="Theme.EchoDrop.BottomSheet" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.EchoDrop.BottomSheet</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="colorPrimary">@color/echo_primary_accent</item>
        <item name="colorSurface">@color/echo_card_surface</item>
        <item name="colorOnSurface">@color/echo_text_primary</item>
        <item name="android:statusBarColor">@color/echo_elevated_surface</item>
        <item name="android:navigationBarColor">@color/echo_elevated_surface</item>
    </style>

    <style name="Widget.EchoDrop.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.EchoDrop.BottomSheet</item>
        <item name="backgroundTint">@color/echo_card_surface</item>
    </style>

    <style name="ShapeAppearance.EchoDrop.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ═══ Snackbar ═══ -->

    <style name="Widget.EchoDrop.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/echo_card_surface</item>
    </style>

</resources>
