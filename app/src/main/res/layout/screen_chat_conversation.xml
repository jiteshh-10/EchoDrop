<?xml version="1.0" encoding="utf-8"?>
<!-- Chat conversation screen: toolbar, sync bar, message list, input bar. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/echo_bg_main">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/app_bar_height"
        android:background="@color/echo_elevated_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="@dimen/min_touch_target"
            android:layout_height="@dimen/min_touch_target"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/content_back"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Avatar + name -->
        <FrameLayout
            android:layout_width="@dimen/chat_avatar_size"
            android:layout_height="@dimen/chat_avatar_size"
            android:layout_marginStart="@dimen/spacing_1">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_chat_avatar" />

            <TextView
                android:id="@+id/toolbar_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:textSize="@dimen/chat_avatar_text_size"
                android:textColor="@color/echo_bg_main"
                tools:text="S" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/echo_text_primary"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Study Group" />

            <TextView
                android:id="@+id/toolbar_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/echo_text_muted"
                android:textSize="11sp"
                tools:text="XKBQ-T7NR" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/toolbar_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/echo_divider"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Sync status sub-bar -->
    <LinearLayout
        android:id="@+id/sync_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/echo_elevated_surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="@dimen/spacing_0_75"
        app:layout_constraintTop_toBottomOf="@id/toolbar_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/sync_dot"
            android:layout_width="@dimen/spacing_0_75"
            android:layout_height="@dimen/spacing_0_75"
            android:background="@drawable/bg_chat_avatar" />

        <TextView
            android:id="@+id/sync_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_0_75"
            android:text="@string/chat_sync_hint"
            android:fontFamily="sans-serif"
            android:textColor="@color/echo_text_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:id="@+id/sync_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/echo_divider"
        app:layout_constraintTop_toBottomOf="@id/sync_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/message_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingVertical="@dimen/spacing_1"
        app:layout_constraintTop_toBottomOf="@id/sync_divider"
        app:layout_constraintBottom_toTopOf="@id/input_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty state (centered over message list) -->
    <TextView
        android:id="@+id/empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/chat_conv_empty"
        android:fontFamily="sans-serif"
        android:textColor="@color/echo_text_muted"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/message_list"
        app:layout_constraintBottom_toBottomOf="@id/message_list"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

    <!-- Input divider -->
    <View
        android:id="@+id/input_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/echo_divider"
        app:layout_constraintBottom_toTopOf="@id/input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Input bar -->
    <LinearLayout
        android:id="@+id/input_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/fab_size"
        android:background="@color/echo_elevated_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_1"
        android:paddingVertical="@dimen/spacing_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/input_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="@dimen/chat_input_height"
            android:background="@drawable/bg_chat_input"
            android:hint="@string/chat_input_hint"
            android:textColorHint="@color/echo_text_muted"
            android:fontFamily="sans-serif"
            android:textColor="@color/echo_text_primary"
            android:textSize="14sp"
            android:paddingHorizontal="@dimen/spacing_2"
            android:paddingVertical="@dimen/spacing_1"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="4"
            android:importantForAutofill="no" />

        <ImageView
            android:id="@+id/btn_send"
            android:layout_width="@dimen/chat_send_size"
            android:layout_height="@dimen/chat_send_size"
            android:layout_marginStart="@dimen/spacing_1"
            android:background="@drawable/bg_send_button"
            android:padding="10dp"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/content_send"
            android:alpha="0.5" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
