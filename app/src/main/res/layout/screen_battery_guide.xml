<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/echo_bg_main"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/battery_toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        android:background="@color/echo_elevated_surface"
        app:navigationIcon="@drawable/ic_back"
        app:navigationContentDescription="@string/content_back"
        app:title="@string/battery_title"
        app:titleTextAppearance="@style/TextAppearance.EchoDrop.H1"
        app:titleTextColor="@color/echo_text_primary" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/echo_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_note"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    style="@style/TextAppearance.EchoDrop.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="keep mesh alive"
                    android:textColor="@color/echo_primary_accent" />

                <TextView
                    style="@style/TextAppearance.EchoDrop.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_0_75"
                    android:text="@string/battery_intro"
                    android:textColor="@color/echo_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_samsung"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/header_samsung"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingTop="@dimen/spacing_1"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/spacing_1">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/battery_samsung" />

                    <ImageView
                        android:id="@+id/arrow_samsung"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_expand"
                        app:tint="@color/echo_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/body_samsung"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/oem_card_padding"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/battery_samsung_step1" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_1"
                        android:text="@string/battery_samsung_step2" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_xiaomi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/header_xiaomi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingTop="@dimen/spacing_1"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/spacing_1">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/battery_xiaomi" />

                    <ImageView
                        android:id="@+id/arrow_xiaomi"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_expand"
                        app:tint="@color/echo_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/body_xiaomi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/oem_card_padding"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/battery_xiaomi_step1" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_1"
                        android:text="@string/battery_xiaomi_step2" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_oneplus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/header_oneplus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingTop="@dimen/spacing_1"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/spacing_1">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/battery_oneplus" />

                    <ImageView
                        android:id="@+id/arrow_oneplus"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_expand"
                        app:tint="@color/echo_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/body_oneplus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/oem_card_padding"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/battery_oneplus_step1" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_realme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/header_realme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingTop="@dimen/spacing_1"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/spacing_1">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/battery_realme" />

                    <ImageView
                        android:id="@+id/arrow_realme"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_expand"
                        app:tint="@color/echo_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/body_realme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/oem_card_padding"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/battery_realme_step1" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_1"
                        android:text="@string/battery_realme_step2" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_stock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:layout_marginBottom="@dimen/spacing_2"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/header_stock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingTop="@dimen/spacing_1"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/spacing_1">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/battery_stock" />

                    <ImageView
                        android:id="@+id/arrow_stock"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_expand"
                        app:tint="@color/echo_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/body_stock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/oem_card_padding"
                    android:paddingRight="@dimen/oem_card_padding"
                    android:paddingBottom="@dimen/oem_card_padding"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/battery_stock_step1" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="@dimen/spacing_2"
        android:paddingTop="@dimen/spacing_1"
        android:paddingRight="@dimen/spacing_2"
        android:paddingBottom="@dimen/spacing_2">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/echo_divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_done"
            style="@style/Widget.EchoDrop.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_primary"
            android:layout_marginTop="@dimen/spacing_2"
            android:text="@string/battery_done" />
    </LinearLayout>
</LinearLayout>
