<?xml version="1.0" encoding="utf-8"?>
<!-- Outgoing (right-aligned) chat message bubble. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/spacing_2"
    android:paddingVertical="3dp">

    <!-- Bubble — right-aligned -->
    <LinearLayout
        android:id="@+id/bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:maxWidth="@dimen/bubble_max_width"
        android:background="@drawable/bg_bubble_outgoing"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/bubble_padding_h"
        android:paddingVertical="@dimen/bubble_padding_v">

        <TextView
            android:id="@+id/message_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:textColor="@color/echo_text_primary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.3"
            tools:text="Hey, are we still meeting at 3?" />

        <!-- Timestamp + sync indicator row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/message_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="@color/echo_text_muted"
                android:textSize="10sp"
                tools:text="3:42 PM" />

            <ImageView
                android:id="@+id/sync_indicator"
                android:layout_width="@dimen/sync_indicator_size"
                android:layout_height="@dimen/sync_indicator_size"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_tick"
                android:importantForAccessibility="no" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
