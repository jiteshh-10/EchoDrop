<?xml version="1.0" encoding="utf-8"?>
<!-- Settings screen layout (Iteration 5) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/echo_bg_main"
    android:orientation="vertical">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        android:background="@color/echo_elevated_surface"
        app:navigationIcon="@drawable/ic_back"
        app:navigationContentDescription="@string/content_back"
        app:title="@string/settings_title"
        app:titleTextColor="@color/echo_text_primary" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/echo_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_2">

            <!-- Section: Nearby Sharing -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:letterSpacing="0.08"
                android:text="@string/settings_nearby_header"
                android:textColor="@color/echo_text_secondary"
                android:textSize="12sp" />

            <!-- Toggle row: Run in background -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:gravity="center_vertical"
                android:minHeight="@dimen/min_touch_target"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_bg_title"
                        android:textColor="@color/echo_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_bg_sub"
                        android:textColor="@color/echo_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_background"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:minWidth="@dimen/min_touch_target"
                    android:minHeight="@dimen/min_touch_target" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="@color/echo_divider" />

            <!-- Battery guide link row -->
            <LinearLayout
                android:id="@+id/battery_guide_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="@dimen/min_touch_target"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/spacing_1">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/content_battery_icon"
                    android:src="@drawable/ic_battery" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_2"
                    android:layout_weight="1"
                    android:text="@string/settings_battery_title"
                    android:textColor="@color/echo_text_primary"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/content_chevron"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- Divider before About -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="@color/echo_divider" />

            <!-- Section: About -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_header_spacing"
                android:letterSpacing="0.08"
                android:text="@string/settings_about_header"
                android:textColor="@color/echo_text_secondary"
                android:textSize="12sp" />

            <!-- Version row (tap 7 times for dev screen) -->
            <TextView
                android:id="@+id/version_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:minHeight="@dimen/min_touch_target"
                android:gravity="center_vertical"
                android:textColor="@color/echo_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
