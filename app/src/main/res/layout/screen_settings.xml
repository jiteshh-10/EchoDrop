<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/echo_bg_main"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        android:background="@color/echo_elevated_surface"
        app:navigationIcon="@drawable/ic_back"
        app:navigationContentDescription="@string/content_back"
        app:title="@string/settings_title"
        app:titleTextColor="@color/echo_text_primary"
        app:titleTextAppearance="@style/TextAppearance.EchoDrop.H1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/echo_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    style="@style/TextAppearance.EchoDrop.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_nearby_header"
                    android:textColor="@color/echo_text_muted" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.EchoDrop.H2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_bg_title" />

                        <TextView
                            style="@style/TextAppearance.EchoDrop.Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_0_25"
                            android:text="@string/settings_bg_sub" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_background"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:layout_marginBottom="@dimen/spacing_1"
                    android:background="@color/echo_divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_holder">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/settings_incoming_alerts_title"
                            android:src="@drawable/ic_bell"
                            app:tint="@color/echo_primary_accent" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.EchoDrop.H2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_incoming_alerts_title" />

                        <TextView
                            style="@style/TextAppearance.EchoDrop.Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_0_25"
                            android:text="@string/settings_incoming_alerts_sub" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_incoming_alerts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    style="@style/TextAppearance.EchoDrop.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_storage_header"
                    android:textColor="@color/echo_text_muted" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_holder">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/settings_storage_cap_title"
                            android:src="@drawable/ic_database"
                            app:tint="@color/echo_primary_accent" />
                    </FrameLayout>

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/settings_storage_cap_title" />

                    <TextView
                        android:id="@+id/storage_cap_value"
                        style="@style/TextAppearance.EchoDrop.Badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/echo_primary_accent" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/storage_cap_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:stepSize="10"
                    android:value="60"
                    android:valueFrom="20"
                    android:valueTo="200"
                    app:haloColor="@color/echo_primary_tint"
                    app:labelBehavior="gone"
                    app:thumbColor="@color/echo_primary_accent"
                    app:trackColorActive="@color/echo_primary_accent"
                    app:trackColorInactive="@color/echo_border" />

                <TextView
                    style="@style/TextAppearance.EchoDrop.Small"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_0_5"
                    android:text="@string/settings_storage_cap_sub"
                    android:textColor="@color/echo_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:id="@+id/battery_guide_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_holder">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/content_battery_icon"
                            android:src="@drawable/ic_battery"
                            app:tint="@color/echo_primary_accent" />
                    </FrameLayout>

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/settings_battery_title" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/echo_text_muted" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:layout_marginBottom="@dimen/spacing_1"
                    android:background="@color/echo_divider" />

                <LinearLayout
                    android:id="@+id/how_it_works_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_holder">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/how_it_works_title"
                            android:src="@drawable/ic_wifi"
                            app:tint="@color/echo_primary_accent" />
                    </FrameLayout>

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/how_it_works_title" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/echo_text_muted" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:layout_marginBottom="@dimen/spacing_1"
                    android:background="@color/echo_divider" />

                <LinearLayout
                    android:id="@+id/diagnostics_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_holder">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/settings_diagnostics_title"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/echo_primary_accent" />
                    </FrameLayout>

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/settings_diagnostics_title" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/echo_text_muted" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:id="@+id/block_device_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_holder">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/settings_block_device_title"
                            android:src="@drawable/ic_alert_outline"
                            app:tint="@color/echo_alert_accent" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.EchoDrop.H2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_block_device_title" />

                        <TextView
                            android:id="@+id/blocked_summary_text"
                            style="@style/TextAppearance.EchoDrop.Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_0_25"
                            android:text="@string/settings_block_device_sub" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/echo_text_muted" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    style="@style/TextAppearance.EchoDrop.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_rooms_header"
                    android:textColor="@color/echo_text_muted" />

                <LinearLayout
                    android:id="@+id/rooms_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/min_touch_target"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_holder">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/chat_list_title"
                            android:src="@drawable/ic_wifi"
                            app:tint="@color/echo_primary_accent" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.EchoDrop.H2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_rooms_title" />

                        <TextView
                            android:id="@+id/rooms_summary_text"
                            style="@style/TextAppearance.EchoDrop.Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_0_25"
                            android:text="@string/settings_rooms_sub_empty" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_chevron"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/echo_text_muted" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:layout_marginBottom="@dimen/spacing_3"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    style="@style/TextAppearance.EchoDrop.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_about_header"
                    android:textColor="@color/echo_text_muted" />

                <TextView
                    android:id="@+id/version_text"
                    style="@style/TextAppearance.EchoDrop.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:background="?attr/selectableItemBackground"
                    android:minHeight="@dimen/min_touch_target"
                    android:gravity="center_vertical"
                    android:textColor="@color/echo_text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
