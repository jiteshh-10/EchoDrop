<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/echo_bg_main"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/how_toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        android:background="@color/echo_elevated_surface"
        android:title="@string/how_it_works_title"
        android:titleTextColor="@color/echo_alert_accent"
        app:titleTextAppearance="@style/TextAppearance.EchoDrop.H1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/echo_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingLeft="@dimen/spacing_1"
                android:paddingTop="@dimen/spacing_1"
                android:paddingRight="@dimen/spacing_1"
                android:paddingBottom="@dimen/spacing_1">

                <FrameLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:background="@drawable/bg_icon_circle_surface">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/how_it_works_headline"
                        android:src="@drawable/ic_wifi"
                        app:tint="@color/echo_alert_accent" />
                </FrameLayout>

                <TextView
                    style="@style/TextAppearance.EchoDrop.Display"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_3"
                    android:gravity="center"
                    android:text="@string/how_it_works_headline" />

                <TextView
                    style="@style/TextAppearance.EchoDrop.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:gravity="center"
                    android:text="@string/how_it_works_subheading"
                    android:textColor="@color/echo_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    style="@style/TextAppearance.EchoDrop.H2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/how_it_works_section" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1_5"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Badge"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/echo_alert_accent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/echo_on_primary" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/how_it_works_step_1"
                        android:textColor="@color/echo_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1_5"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Badge"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/echo_alert_accent"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/echo_on_primary" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/how_it_works_step_2"
                        android:textColor="@color/echo_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1_5"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Badge"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/echo_alert_accent"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/echo_on_primary" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/how_it_works_step_3"
                        android:textColor="@color/echo_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1_5"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Badge"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/echo_alert_accent"
                        android:gravity="center"
                        android:text="4"
                        android:textColor="@color/echo_on_primary" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/how_it_works_step_4"
                        android:textColor="@color/echo_text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/TextAppearance.EchoDrop.H2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_3"
                android:text="@string/how_it_works_key_features" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_icon_circle_surface">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/how_it_works_tile_1_title"
                        android:src="@drawable/ic_wifi"
                        app:tint="@color/echo_alert_accent" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_1_5"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/spacing_0_25"
                    android:paddingBottom="@dimen/spacing_0_25">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/how_it_works_tile_1_title" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_5"
                        android:text="@string/how_it_works_tile_1_sub" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_icon_circle_surface">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/how_it_works_tile_2_title"
                        android:src="@drawable/ic_clock"
                        app:tint="@color/echo_alert_accent" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_1_5"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/spacing_0_25"
                    android:paddingBottom="@dimen/spacing_0_25">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/how_it_works_tile_2_title" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_5"
                        android:text="@string/how_it_works_tile_2_sub" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_icon_circle_surface">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/how_it_works_tile_3_title"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/echo_alert_accent" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_1_5"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/spacing_0_25"
                    android:paddingBottom="@dimen/spacing_0_25">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/how_it_works_tile_3_title" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_5"
                        android:text="@string/how_it_works_tile_3_sub" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_icon_circle_surface">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/how_it_works_tile_4_title"
                        android:src="@drawable/ic_activity"
                        app:tint="@color/echo_alert_accent" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_1_5"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/spacing_0_25"
                    android:paddingBottom="@dimen/spacing_0_25">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/how_it_works_tile_4_title" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_5"
                        android:text="@string/how_it_works_tile_4_sub" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/TextAppearance.EchoDrop.H2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_3"
                android:text="@string/how_it_works_use_cases" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_circle_surface"
                        android:gravity="center"
                        android:text="@string/how_it_works_use_case_campus_icon"
                        android:textSize="18sp" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/how_it_works_use_case_campus_title" />
                </LinearLayout>

                <TextView
                    style="@style/TextAppearance.EchoDrop.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:text="@string/how_it_works_use_case_campus_sub"
                    android:textColor="@color/echo_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_circle_surface"
                        android:gravity="center"
                        android:text="@string/how_it_works_use_case_emergency_icon"
                        android:textSize="18sp" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/how_it_works_use_case_emergency_title" />
                </LinearLayout>

                <TextView
                    style="@style/TextAppearance.EchoDrop.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:text="@string/how_it_works_use_case_emergency_sub"
                    android:textColor="@color/echo_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_circle_surface"
                        android:gravity="center"
                        android:text="@string/how_it_works_use_case_events_icon"
                        android:textSize="18sp" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_1_5"
                        android:layout_weight="1"
                        android:text="@string/how_it_works_use_case_events_title" />
                </LinearLayout>

                <TextView
                    style="@style/TextAppearance.EchoDrop.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_1"
                    android:text="@string/how_it_works_use_case_events_sub"
                    android:textColor="@color/echo_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_3"
                android:layout_marginBottom="@dimen/spacing_2"
                android:background="@drawable/bg_stat_card"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/echo_alert_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        style="@style/TextAppearance.EchoDrop.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/how_it_works_technical_title" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_1"
                        android:text="@string/how_it_works_tech_1"
                        android:textColor="@color/echo_text_secondary" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_75"
                        android:text="@string/how_it_works_tech_2"
                        android:textColor="@color/echo_text_secondary" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_75"
                        android:text="@string/how_it_works_tech_3"
                        android:textColor="@color/echo_text_secondary" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_75"
                        android:text="@string/how_it_works_tech_4"
                        android:textColor="@color/echo_text_secondary" />

                    <TextView
                        style="@style/TextAppearance.EchoDrop.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_75"
                        android:text="@string/how_it_works_tech_5"
                        android:textColor="@color/echo_text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="@dimen/spacing_3"
        android:paddingTop="@dimen/spacing_1"
        android:paddingRight="@dimen/spacing_3"
        android:paddingBottom="@dimen/spacing_3">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/echo_divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/how_get_started"
            style="@style/Widget.EchoDrop.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_primary"
            android:layout_marginTop="@dimen/spacing_2"
            android:text="@string/how_it_works_get_started" />
    </LinearLayout>
</LinearLayout>
