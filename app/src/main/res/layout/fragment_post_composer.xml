<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/echo_card_surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_2">

        <TextView
            android:id="@+id/post_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:text="@string/post_new_title"
            android:textColor="@color/echo_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/post_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/content_close"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/echo_text_primary" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/echo_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_2">

            <EditText
                android:id="@+id/post_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_search_input"
                android:gravity="top"
                android:hint="@string/post_hint"
                android:inputType="textMultiLine"
                android:maxLength="240"
                android:maxLines="4"
                android:minLines="4"
                android:padding="12dp"
                android:textColor="@color/echo_text_primary"
                android:textColorHint="@color/echo_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/post_char_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:text="@string/post_char_counter"
                android:textColor="@color/echo_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_3"
                android:fontFamily="sans-serif"
                android:text="@string/post_scope_label"
                android:textColor="@color/echo_text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/scope_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_scope_nearby"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_scope_nearby" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_scope_area"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_scope_area" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_scope_event"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_scope_event" />
            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:id="@+id/post_scope_custom_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif"
                android:text="@string/post_scope_custom_label"
                android:textColor="@color/echo_text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/post_scope_custom_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_input"
                android:hint="@string/post_scope_custom_hint_zone"
                android:inputType="textCapWords"
                android:maxLength="40"
                android:padding="12dp"
                android:textColor="@color/echo_text_primary"
                android:textColorHint="@color/echo_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/urgent_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_3"
                android:fontFamily="sans-serif"
                android:text="@string/post_mark_urgent"
                android:textColor="@color/echo_text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/urgent_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/urgent_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:text="@string/post_urgent_hint"
                android:textColor="@color/echo_alert_accent"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_3"
                android:fontFamily="sans-serif"
                android:text="@string/post_expires_in"
                android:textColor="@color/echo_text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/ttl_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_ttl_1h"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_ttl_1h" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_ttl_4h"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_ttl_4h" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_ttl_12h"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_ttl_12h" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_ttl_24h"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_ttl_24h" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/post_cancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/post_cancel"
            android:textColor="@color/echo_text_secondary"
            app:cornerRadius="@dimen/card_corner_radius"
            app:strokeColor="@color/echo_border"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/post_submit"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/post_submit"
            android:textColor="@color/echo_text_primary"
            app:cornerRadius="@dimen/card_corner_radius"
            app:backgroundTint="@color/echo_primary_accent" />
    </LinearLayout>
</LinearLayout>
