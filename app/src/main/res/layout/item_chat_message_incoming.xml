<?xml version="1.0" encoding="utf-8"?>
<!-- Incoming (left-aligned) chat message bubble with left accent border. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/spacing_2"
    android:paddingVertical="3dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="horizontal">

        <!-- Left accent border -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="@color/echo_primary_accent" />

        <!-- Bubble content -->
        <LinearLayout
            android:id="@+id/bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/bubble_max_width"
            android:background="@drawable/bg_bubble_incoming"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/bubble_padding_h"
            android:paddingVertical="@dimen/bubble_padding_v">

            <TextView
                android:id="@+id/message_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/echo_text_primary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3"
                tools:text="Yes! Let me grab my stuff." />

            <TextView
                android:id="@+id/message_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="2dp"
                android:fontFamily="monospace"
                android:textColor="@color/echo_text_muted"
                android:textSize="10sp"
                tools:text="3:43 PM" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
